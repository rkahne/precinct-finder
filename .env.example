# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://precinct_user:your_password@localhost/precinctdb

# Google Sheets export (optional — leave blank to disable)
# 1. Create a service account in Google Cloud Console
# 2. Enable the Google Sheets API
# 3. Download the JSON key and place it on the server
# 4. Share your target spreadsheet with the service account email
GOOGLE_CREDENTIALS_FILE=/opt/precinct-finder/google-credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Server port (default: 5000)
PORT=5000
